---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadSiteData } from "../lib/content";

const site = loadSiteData();
const heroCards = site.home.heroCards;
---

<BaseLayout
  title={site.person.name}
  description="Adarsh Uday. Supply chain engineering and mechanical engineering work from IIT Madras to Georgia Tech."
  sectionTone="home"
>
  <section class="home-hero home-hero--minimal panel">
    <div class="hero-copy hero-copy--minimal">
      <h1 class="display">{site.person.name}</h1>
      <p class="hero-kicker">{site.person.title}</p>
      <p class="lede">{site.person.intro[0]}</p>
    </div>

    <div class="hero-visual hero-visual--minimal">
      {heroCards.map((card, index) => (
        <article class:list={["hero-card", { "hero-card-main": index === 0, "hero-card-secondary": index === 1, "hero-card-tertiary": index === 2 }]}>
          <p class="mono">{card.label}</p>
          {card.title && <h2>{card.title}</h2>}
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>