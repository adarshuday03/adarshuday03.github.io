---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntryCard from "../../components/EntryCard.astro";
import PageIntro from "../../components/PageIntro.astro";
import { getProjectsByInstitution, loadSiteData } from "../../lib/content";

const site = loadSiteData();
const projects = getProjectsByInstitution("bachelors");
---

<BaseLayout title="Bachelors" description={site.institutions.bachelors.summary[0]} sectionTone="bachelors">
  <section class="section-shell">
    <PageIntro
      eyebrow="IIT Madras"
      title={site.institutions.bachelors.headline}
      summary={site.institutions.bachelors.summary}
    />

    <div class="metric-grid">
      {site.institutions.bachelors.stats.map((stat) => (
        <article class="metric-card">
          <p class="mono">{stat.label}</p>
          <p>{stat.value}</p>
        </article>
      ))}
    </div>

    <div class="tag-row">
      {site.institutions.bachelors.focusAreas.map((focusArea) => (
        <span class="tag">{focusArea}</span>
      ))}
    </div>

    <div class="empty-state">{site.institutions.bachelors.buildNote}</div>
  </section>

  <section class="section-shell">
    <PageIntro
      eyebrow="Projects"
      title="Coursework, research, and build work"
      summary="The IIT Madras arc moves from mechanism design and factory simulation to biomechanics, analytics, and campus-built software."
      level="h2"
    />

    {projects.length === 0 ? (
      <div class="empty-state">
        No published undergraduate project manifests yet.
      </div>
    ) : (
      <div class="entry-stack">
        {projects.map((project) => (
          <EntryCard
            title={project.title}
            meta={[project.timeline.label, project.semester, project.course.name]}
            summary={project.summary}
            bullets={project.highlights}
            tags={project.tags}
            href={project.href}
            ctaLabel="Open case study"
          />
        ))}
      </div>
    )}
  </section>

  <section class="section-shell">
    <PageIntro
      eyebrow="Leadership"
      title="Campus leadership and service"
      summary="Mentoring, operations, and community-facing work beyond coursework and formal project teams."
      level="h2"
    />

    <div class="entry-stack">
      {site.resume.leadership.map((entry) => (
        <EntryCard
          title={entry.title}
          meta={[entry.period, entry.subtitle]}
          summary={entry.summary}
          bullets={entry.bullets}
          tags={entry.tags}
        />
      ))}
    </div>
  </section>

  <section class="section-shell">
    <PageIntro
      eyebrow="Extracurriculars"
      title="Creative and campus life"
      summary="The performance, collaboration, and cultural side of the IIT Madras years."
      level="h2"
    />

    <div class="entry-stack">
      {site.resume.extracurriculars.map((entry) => (
        <EntryCard
          title={entry.title}
          meta={[entry.period, entry.subtitle]}
          summary={entry.summary}
          bullets={entry.bullets}
          tags={entry.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>