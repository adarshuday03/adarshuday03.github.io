---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageIntro from "../../components/PageIntro.astro";
import { loadSiteData } from "../../lib/content";

const site = loadSiteData();
---

<BaseLayout title="About / Now" description={site.about.sections[0].body[0]}>
  <section class="section-shell">
    <PageIntro
      eyebrow="About / Now"
      title="What sits underneath the project list"
      summary="This section holds the connective tissue between the resume, the archive, and the way the work is approached."
    />

    <div class="entry-stack">
      {site.about.sections.map((section) => (
        <article class="entry-card">
          <div class="entry-card-header">
            <h3 class="entry-title">{section.title}</h3>
          </div>
          {section.body.map((paragraph) => (
            <p class="note">{paragraph}</p>
          ))}
        </article>
      ))}
    </div>
  </section>

  <section class="section-shell">
    <PageIntro
      eyebrow="Skills"
      title="Tooling and technical languages"
      summary="The skill layer is kept in site-content so it stays easy to update as tools and languages evolve."
      level="h2"
    />

    <div class="skill-grid">
      {site.resume.skills.map((group) => (
        <article class="skill-card">
          <p class="mono">{group.title}</p>
          <div class="tag-row">
            {group.items.map((item) => (
              <span class="tag">{item}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>